---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/image9.jpg';
---

<section class="hero" aria-label="Introduction">
  <div class="hero-bg">
    <Image
      src={heroImage}
      alt="Mohan in front of the Chicago skyline"
      width={1920}
      height={1080}
      quality={90}
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>
  <div class="container hero-inner">
    <p class="hero-greeting">// hello, world</p>
    <h1 class="hero-name">Mohan Dasari</h1>
    <p class="hero-title">Platform / Developer Productivity Engineer</p>
    <p class="hero-tagline">
      Specializing in high-throughput CI systems, infrastructure optimization,
      and internal AI tooling. CKA certified.
    </p>
    <div class="hero-actions">
      <a href="#projects" class="btn btn-primary">View Projects</a>
      <a href="#contact" class="btn btn-secondary">Contact Me</a>
      <a href="/Mohan_Dasari_Resume.pdf" class="btn btn-secondary" download>Download Resume</a>
    </div>
  </div>
</section>

<style>
  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--bg) 0%,
      transparent 50%,
      rgba(0, 0, 0, 0.3) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 4rem 1.5rem;
  }

  .hero-greeting {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 1rem;
    color: var(--accent);
    font-weight: 400;
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.2s forwards;
  }

  .hero-name {
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: -1.5px;
    color: #f0f0f5;
    margin-bottom: 0.25rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.4s forwards;
  }

  .hero-title {
    font-size: 1.5rem;
    color: #ccc;
    font-weight: 400;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.6s forwards;
  }

  .hero-tagline {
    font-size: 1.125rem;
    color: #aaa;
    margin-bottom: 2.5rem;
    max-width: 550px;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.8s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 1.0s forwards;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: var(--bg);
  }

  .btn-secondary {
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    color: #f0f0f5;
    background: transparent;
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: 2.75rem;
    }

    .hero-title {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .hero-name {
      font-size: 2.25rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      text-align: center;
    }
  }
</style>
