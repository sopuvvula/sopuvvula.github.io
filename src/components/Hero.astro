---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/image9.jpg';
---

<section class="hero" aria-label="Introduction">
  <div class="hero-text">
    <div class="hero-text-inner">
      <p class="hero-greeting">// hello, world. i'm</p>
      <h1 class="hero-name">Mohan Dasari</h1>
      <p class="hero-title">Platform / Developer Productivity Engineer</p>
      <p class="hero-tagline">
        Specializing in high-throughput CI systems, infrastructure optimization,
        and internal AI tooling. CKA certified.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">View Projects</a>
        <a href="#contact" class="btn btn-secondary">Contact Me</a>
        <a href="/Mohan_Dasari_Resume.pdf" class="btn btn-secondary" download>Download Resume</a>
      </div>
    </div>
  </div>
  <div class="hero-photo">
    <Image
      src={heroImage}
      alt="Mohan in front of the Chicago skyline"
      width={960}
      height={1080}
      quality={95}
      loading="eager"
    />
  </div>
</section>

<style>
  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero {
    height: 100vh;
    display: flex;
    padding-top: 64px;
    overflow: hidden;
  }

  .hero-text {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 3rem;
  }

  .hero-text-inner {
    max-width: 520px;
    margin-left: auto;
    margin-right: 3rem;
  }

  .hero-photo {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .hero-photo img {
    width: 110%;
    height: 110%;
    object-fit: cover;
    object-position: center 30%;
    margin: -5%;
    transition: transform 0.3s ease-out;
    will-change: transform;
  }

  .hero-greeting {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 1rem;
    color: var(--accent);
    font-weight: 400;
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.2s forwards;
  }

  .hero-name {
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: -1.5px;
    color: var(--heading);
    margin-bottom: 0.25rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.4s forwards;
  }

  .hero-title {
    font-size: 1.5rem;
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.6s forwards;
  }

  .hero-tagline {
    font-size: 1.125rem;
    color: var(--text-faint);
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.8s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 1.0s forwards;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: var(--bg);
  }

  .btn-secondary {
    border: 1.5px solid var(--border);
    color: var(--text);
    background: transparent;
  }

  .btn-secondary:hover {
    border-color: var(--border-hover);
    color: var(--heading);
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
    }

    .hero-text {
      padding: 2.5rem 1.5rem;
    }

    .hero-text-inner {
      max-width: none;
      margin-left: 0;
      margin-right: 0;
    }

    .hero-photo {
      height: 50vh;
      flex: none;
    }

    .hero-name {
      font-size: 2.75rem;
    }

    .hero-title {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .hero-name {
      font-size: 2.25rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      text-align: center;
    }
  }
</style>

<script>
  const photo = document.querySelector('.hero-photo') as HTMLElement;
  const img = photo?.querySelector('img') as HTMLElement;

  if (photo && img) {
    photo.addEventListener('mousemove', (e) => {
      const { left, top, width, height } = photo.getBoundingClientRect();
      const x = ((e.clientX - left) / width - 0.5) * -30;
      const y = ((e.clientY - top) / height - 0.5) * -30;
      img.style.transform = `translate(${x}px, ${y}px) scale(1.03)`;
    });

    photo.addEventListener('mouseleave', () => {
      img.style.transform = 'translate(0, 0) scale(1)';
    });
  }
</script>
