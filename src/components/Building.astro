---
import { Image } from 'astro:assets';
import northvaleImg from '../assets/images/clients/northvale.jpg';
import bicImg from '../assets/images/clients/bic.jpg';
import vsImg from '../assets/images/clients/vs-caterers.jpg';
import nailImg from '../assets/images/clients/nail-story.jpg';
import kaviImg from '../assets/images/kavi.jpg';

const clients = [
  {
    name: 'North Vale',
    category: 'Property maintenance',
    url: 'https://www.northvalepm.org',
    img: northvaleImg,
  },
  {
    name: 'Best in Class',
    category: 'B2B consulting',
    url: 'https://bic-beta.vercel.app',
    img: bicImg,
  },
  {
    name: 'VS Caterers',
    category: 'Andhra catering',
    url: 'https://svr-catering.vercel.app',
    img: vsImg,
  },
  {
    name: 'Nail Story',
    category: 'Nail salon',
    url: 'https://nail-story.vercel.app',
    img: nailImg,
  },
];
---

<section id="building" class="section" aria-label="Ventures">
  <span class="section-label">// building</span>
  <div class="container">
    <h2 class="section-title fade-in">Ventures</h2>
    <p class="building-intro fade-in">
      Three ventures I started and still run, from the products I ship to the
      bets I back.
    </p>

    <div class="ventures-grid fade-in">
      <!-- ===== Sevro ===== -->
      <article class="venture-card">
        <div class="venture-head">
          <a
            href="https://sevro.me"
            target="_blank"
            rel="noopener noreferrer"
            class="venture-brand"
            aria-label="Sevro"
          >
            <svg class="sevro-mark" viewBox="0 0 409 424" aria-hidden="true">
              <g transform="translate(-2.06, 740) scale(0.1, -0.1)" fill="#f59e0b" stroke="none">
                <path d="M1995 7381 c-219 -64 -400 -250 -450 -465 -21 -89 -19 -211 5 -290 42 -134 167 -253 312 -297 189 -58 441 19 591 180 292 312 220 760 -140 871 -84 26 -232 26 -318 1z" />
                <path d="M3091 6259 c-164 -10 -399 -38 -611 -74 -886 -152 -1647 -497 -1960 -890 -151 -189 -207 -388 -166 -585 69 -330 433 -639 756 -644 76 -1 92 2 145 29 47 23 66 41 90 79 28 47 30 55 37 210 10 240 59 393 171 542 248 328 654 485 1483 574 441 48 659 97 843 190 154 77 231 166 231 267 0 233 -361 339 -1019 302z" />
                <path d="M2292 5175 c-114 -25 -182 -83 -197 -165 -8 -44 3 -73 70 -185 111 -184 112 -351 5 -529 -204 -339 -830 -648 -1739 -857 -257 -59 -304 -73 -355 -102 -49 -28 -65 -51 -50 -74 22 -35 63 -54 159 -76 93 -20 126 -22 460 -21 382 0 476 7 815 60 591 93 1151 274 1515 489 318 189 503 401 537 617 52 341 -297 682 -839 819 -140 35 -291 45 -381 24z" />
              </g>
            </svg>
            <span class="venture-name">Sevro</span>
          </a>
          <span class="venture-status">
            <span class="status-dot" aria-hidden="true"></span>Live
          </span>
        </div>
        <p class="venture-meta">// solo build · product, design, infrastructure</p>
        <p class="venture-desc">
          A resume becomes a polished personal website in about a minute. Upload
          a file, pick a template, and publish to a free yourname.sevro.me
          subdomain or export the HTML to host it anywhere.
        </p>
        <div class="venture-tags">
          {['Next.js', 'TypeScript', 'Vercel', 'Neon', 'Stripe'].map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
        <a
          href="https://sevro.me"
          target="_blank"
          rel="noopener noreferrer"
          class="venture-link"
        >
          Visit sevro.me <span aria-hidden="true">&rarr;</span>
        </a>
      </article>

      <!-- ===== Sitecraft ===== -->
      <article class="venture-card">
        <div class="venture-head">
          <a
            href="https://sitecraft.app"
            target="_blank"
            rel="noopener noreferrer"
            class="venture-brand"
            aria-label="Sitecraft"
          >
            <img
              src="/images/sitecraft-logo-light.png"
              alt="Sitecraft"
              class="sc-lockup brand-on-dark"
            />
            <img
              src="/images/sitecraft-logo.png"
              alt="Sitecraft"
              class="sc-lockup brand-on-light"
            />
          </a>
          <span class="venture-status">
            <span class="status-dot" aria-hidden="true"></span>Live
          </span>
        </div>
        <p class="venture-meta">// solo build · factory tooling + client delivery</p>
        <p class="venture-desc">
          A hands-on web studio for local businesses that never had a real
          website. Shared tooling builds each client a fast, hand-finished site
          in hours, sold in person and maintained for a flat monthly fee.
        </p>
        <div class="venture-tags">
          {['Next.js', 'Tailwind CSS', 'Vercel'].map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>

        <div class="client-block">
          <p class="client-label">Live client work</p>
          <div class="client-grid">
            {clients.map((c) => (
              <a
                href={c.url}
                target="_blank"
                rel="noopener noreferrer"
                class="client-card"
              >
                <div class="client-thumb">
                  <Image src={c.img} alt={`${c.name} website`} width={480} />
                </div>
                <div class="client-info">
                  <span class="client-name">{c.name}</span>
                  <span class="client-cat">{c.category}</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <a
          href="https://sitecraft.app"
          target="_blank"
          rel="noopener noreferrer"
          class="venture-link"
        >
          Visit sitecraft.app <span aria-hidden="true">&rarr;</span>
        </a>
      </article>

      <!-- ===== Shoal n Stone ===== -->
      <article class="venture-card">
        <div class="venture-head">
          <span class="venture-brand">
            <svg class="shoal-mark" viewBox="0 0 950 957" aria-hidden="true">
              <g transform="translate(0,957) scale(0.1,-0.1)" fill="currentColor" stroke="none">
                <path d="M4420 9314 c-588 -50 -1176 -215 -1685 -474 -1798 -914 -2795 -2967 -2400 -4945 381 -1910 1951 -3368 3897 -3620 687 -88 1469 12 2143 276 1233 482 2213 1515 2642 2784 378 1122 297 2354 -227 3430 -631 1294 -1796 2201 -3179 2475 -306 61 -434 72 -806 75 -187 1 -360 1 -385 -1z m748 -280 c806 -83 1571 -397 2212 -910 158 -127 499 -463 626 -617 528 -643 873 -1461 966 -2292 17 -160 18 -752 0 -895 -129 -1049 -550 -1910 -1283 -2625 -672 -655 -1512 -1054 -2469 -1172 -205 -25 -740 -25 -920 0 -332 47 -576 101 -821 181 -1617 533 -2765 1945 -2951 3631 -20 182 -17 723 4 895 90 710 323 1350 695 1912 874 1319 2397 2051 3941 1892z" />
                <path d="M4655 5804 c-50 -13 -107 -45 -525 -298 -245 -148 -562 -339 -705 -425 l-260 -156 -345 -134 c-190 -73 -361 -141 -380 -151 -20 -10 -164 -114 -320 -231 -157 -117 -336 -250 -398 -296 -135 -100 -154 -132 -107 -178 l24 -25 3114 0 3114 0 21 23 c27 28 28 71 4 95 -10 9 -65 51 -123 93 -57 42 -211 155 -341 252 -131 97 -247 181 -260 188 -12 6 -191 67 -398 133 -207 67 -396 134 -421 149 -24 14 -185 147 -357 295 -172 148 -331 278 -355 289 -23 12 -227 100 -454 197 -405 174 -467 195 -528 180z" />
                <path d="M1115 3625 c-14 -13 -25 -33 -25 -45 0 -11 11 -32 25 -45 l24 -25 3609 0 3609 0 27 21 c40 32 35 83 -11 108 -16 8 -930 11 -3628 11 l-3606 0 -24 -25z" />
                <path d="M2070 2930 c-11 -11 -20 -31 -20 -45 0 -14 9 -34 20 -45 20 -20 33 -20 2680 -20 2647 0 2660 0 2680 20 11 11 20 31 20 45 0 14 -9 34 -20 45 -20 20 -33 20 -2680 20 -2647 0 -2660 0 -2680 -20z" />
                <path d="M3212 2244 c-28 -19 -30 -74 -3 -98 17 -16 123 -17 1538 -17 836 0 1527 3 1536 7 8 3 21 19 28 35 10 26 9 34 -8 57 l-20 27 -1524 3 c-1368 2 -1527 0 -1547 -14z" />
              </g>
            </svg>
            <span class="venture-name">Shoal n Stone</span>
          </span>
          <span class="venture-status">
            <span class="status-dot" aria-hidden="true"></span>Active
          </span>
        </div>
        <p class="venture-meta">// solo venture · sourcing, capital, conviction</p>
        <p class="venture-desc">
          My investment firm: a personal vehicle for backing small, early
          companies worth believing in. Its first position is a contribution
          into Kavi Media, with more to follow as the thesis sharpens.
        </p>
        <div class="venture-tags">
          {['Investing', 'Early-stage', 'Long-term'].map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>

        <div class="client-block">
          <p class="client-label">First investment</p>
          <a
            href="https://kavi.audio"
            target="_blank"
            rel="noopener noreferrer"
            class="client-card"
          >
            <div class="client-thumb">
              <Image src={kaviImg} alt="Kavi Media website" width={960} />
            </div>
            <div class="client-info">
              <span class="client-name">Kavi Media</span>
              <span class="client-cat">Telugu audio platform · kavi.audio</span>
            </div>
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .section-title {
    margin-bottom: 1.25rem;
  }

  .building-intro {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 60ch;
    margin-bottom: 3rem;
  }

  .ventures-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .venture-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.85rem;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .venture-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 4px 30px var(--shadow);
  }

  /* ===== Head: brand + status ===== */
  .venture-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .venture-brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }

  .sevro-mark {
    height: 1.75rem;
    width: auto;
    flex-shrink: 0;
  }

  .shoal-mark {
    height: 1.7rem;
    width: auto;
    flex-shrink: 0;
    color: #e8dcc0;
  }

  :global([data-theme='vanilla']) .shoal-mark {
    color: #8c7448;
  }

  .venture-name {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--heading);
  }

  .sc-lockup {
    height: 1.4rem;
    width: auto;
  }

  .brand-on-light {
    display: none;
  }

  :global([data-theme='vanilla']) .brand-on-dark {
    display: none;
  }

  :global([data-theme='vanilla']) .brand-on-light {
    display: inline;
  }

  .venture-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.5px;
    color: var(--text-muted);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #3dc98a;
    box-shadow: 0 0 8px rgba(61, 201, 138, 0.6);
  }

  /* ===== Body ===== */
  .venture-meta {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }

  .venture-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .venture-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--tag-text);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 500;
    border: 1px solid var(--tag-border);
  }

  /* ===== Client work / investment block ===== */
  .client-block {
    padding-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--border);
  }

  /* When the block is the last thing in a card, pin it to the bottom */
  .client-block:last-child {
    margin-top: auto;
    margin-bottom: 0;
  }

  .client-label {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }

  .client-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }

  .client-card {
    display: block;
    color: inherit;
  }

  .client-thumb {
    aspect-ratio: 16 / 10;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .client-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .client-info {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
  }

  .client-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--heading);
    transition: color 0.2s ease;
  }

  .client-cat {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .client-card:hover .client-thumb {
    border-color: var(--border-hover);
    transform: translateY(-3px);
  }

  .client-card:hover .client-name {
    color: var(--accent);
  }

  /* ===== Footer link ===== */
  .venture-link {
    margin-top: auto;
    padding-top: 0.25rem;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .venture-link:hover {
    color: var(--accent-hover);
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .ventures-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 420px) {
    .venture-card {
      padding: 1.5rem;
    }
  }
</style>
