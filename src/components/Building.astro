---
import { Image } from 'astro:assets';
import northvaleImg from '../assets/images/clients/northvale.jpg';
import bicImg from '../assets/images/clients/bic.jpg';
import vsImg from '../assets/images/clients/vs-caterers.jpg';
import nailImg from '../assets/images/clients/nail-story.jpg';

const clients = [
  {
    name: 'North Vale',
    category: 'Property maintenance',
    url: 'https://www.northvalepm.org',
    img: northvaleImg,
  },
  {
    name: 'Best in Class',
    category: 'B2B consulting',
    url: 'https://bic-beta.vercel.app',
    img: bicImg,
  },
  {
    name: 'VS Caterers',
    category: 'Andhra catering',
    url: 'https://svr-catering.vercel.app',
    img: vsImg,
  },
  {
    name: 'Nail Story',
    category: 'Nail salon',
    url: 'https://nail-story.vercel.app',
    img: nailImg,
  },
];
---

<section id="building" class="section" aria-label="Ventures">
  <span class="section-label">// building</span>
  <div class="container">
    <h2 class="section-title fade-in">Ventures</h2>
    <p class="building-intro fade-in">
      Two products I design, build, ship, and run end to end, from the first
      commit to live customers.
    </p>

    <div class="ventures-grid fade-in">
      <!-- ===== Sevro ===== -->
      <article class="venture-card">
        <div class="venture-head">
          <a
            href="https://sevro.me"
            target="_blank"
            rel="noopener noreferrer"
            class="venture-brand"
            aria-label="Sevro"
          >
            <svg class="sevro-mark" viewBox="0 0 409 424" aria-hidden="true">
              <g transform="translate(-2.06, 740) scale(0.1, -0.1)" fill="#f59e0b" stroke="none">
                <path d="M1995 7381 c-219 -64 -400 -250 -450 -465 -21 -89 -19 -211 5 -290 42 -134 167 -253 312 -297 189 -58 441 19 591 180 292 312 220 760 -140 871 -84 26 -232 26 -318 1z" />
                <path d="M3091 6259 c-164 -10 -399 -38 -611 -74 -886 -152 -1647 -497 -1960 -890 -151 -189 -207 -388 -166 -585 69 -330 433 -639 756 -644 76 -1 92 2 145 29 47 23 66 41 90 79 28 47 30 55 37 210 10 240 59 393 171 542 248 328 654 485 1483 574 441 48 659 97 843 190 154 77 231 166 231 267 0 233 -361 339 -1019 302z" />
                <path d="M2292 5175 c-114 -25 -182 -83 -197 -165 -8 -44 3 -73 70 -185 111 -184 112 -351 5 -529 -204 -339 -830 -648 -1739 -857 -257 -59 -304 -73 -355 -102 -49 -28 -65 -51 -50 -74 22 -35 63 -54 159 -76 93 -20 126 -22 460 -21 382 0 476 7 815 60 591 93 1151 274 1515 489 318 189 503 401 537 617 52 341 -297 682 -839 819 -140 35 -291 45 -381 24z" />
              </g>
            </svg>
            <span class="venture-name">Sevro</span>
          </a>
          <span class="venture-status">
            <span class="status-dot" aria-hidden="true"></span>Live
          </span>
        </div>
        <p class="venture-meta">// solo build · product, design, infrastructure</p>
        <p class="venture-desc">
          A resume becomes a polished personal website in about a minute. Upload
          a file or paste text, pick a template, and publish to a free
          yourname.sevro.me subdomain, or export the HTML and host it anywhere.
          Self-serve, with a free tier and paid plans for custom domains and
          hosted editing.
        </p>
        <div class="venture-tags">
          {['Next.js', 'TypeScript', 'Vercel', 'Neon', 'Stripe'].map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
        <a
          href="https://sevro.me"
          target="_blank"
          rel="noopener noreferrer"
          class="venture-link"
        >
          Visit sevro.me <span aria-hidden="true">&rarr;</span>
        </a>
      </article>

      <!-- ===== Sitecraft ===== -->
      <article class="venture-card">
        <div class="venture-head">
          <a
            href="https://sitecraft.app"
            target="_blank"
            rel="noopener noreferrer"
            class="venture-brand"
            aria-label="Sitecraft"
          >
            <img
              src="/images/sitecraft-logo-light.png"
              alt="Sitecraft"
              class="sc-lockup brand-on-dark"
            />
            <img
              src="/images/sitecraft-logo.png"
              alt="Sitecraft"
              class="sc-lockup brand-on-light"
            />
          </a>
          <span class="venture-status">
            <span class="status-dot" aria-hidden="true"></span>Live
          </span>
        </div>
        <p class="venture-meta">// solo build · factory tooling + client delivery</p>
        <p class="venture-desc">
          A hands-on web studio for local businesses that never had a real
          website. Sitecraft runs on a factory model: shared tooling scaffolds
          each client a fast, hand-finished site in hours, sold in person and
          maintained for a flat monthly fee.
        </p>
        <div class="venture-tags">
          {['Next.js', 'Tailwind CSS', 'Vercel'].map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>

        <div class="client-block">
          <p class="client-label">Live client work</p>
          <div class="client-grid">
            {clients.map((c) => (
              <a
                href={c.url}
                target="_blank"
                rel="noopener noreferrer"
                class="client-card"
              >
                <div class="client-thumb">
                  <Image src={c.img} alt={`${c.name} website`} width={480} />
                </div>
                <div class="client-info">
                  <span class="client-name">{c.name}</span>
                  <span class="client-cat">{c.category}</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <a
          href="https://sitecraft.app"
          target="_blank"
          rel="noopener noreferrer"
          class="venture-link"
        >
          Visit sitecraft.app <span aria-hidden="true">&rarr;</span>
        </a>
      </article>
    </div>
  </div>
</section>

<style>
  .section-title {
    margin-bottom: 1.25rem;
  }

  .building-intro {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 60ch;
    margin-bottom: 3rem;
  }

  .ventures-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .venture-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .venture-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 4px 30px var(--shadow);
  }

  /* ===== Head: brand + status ===== */
  .venture-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .venture-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
  }

  .sevro-mark {
    height: 1.85rem;
    width: auto;
    flex-shrink: 0;
  }

  .venture-name {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--heading);
  }

  .sc-lockup {
    height: 1.5rem;
    width: auto;
  }

  .brand-on-light {
    display: none;
  }

  :global([data-theme='vanilla']) .brand-on-dark {
    display: none;
  }

  :global([data-theme='vanilla']) .brand-on-light {
    display: inline;
  }

  .venture-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.5px;
    color: var(--text-muted);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #3dc98a;
    box-shadow: 0 0 8px rgba(61, 201, 138, 0.6);
  }

  /* ===== Body ===== */
  .venture-meta {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }

  .venture-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .venture-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--tag-text);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    border: 1px solid var(--tag-border);
  }

  /* ===== Client work ===== */
  .client-block {
    padding-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .client-label {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }

  .client-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }

  .client-card {
    display: block;
    color: inherit;
  }

  .client-thumb {
    aspect-ratio: 16 / 10;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .client-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .client-info {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
  }

  .client-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--heading);
    transition: color 0.2s ease;
  }

  .client-cat {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .client-card:hover .client-thumb {
    border-color: var(--border-hover);
    transform: translateY(-3px);
  }

  .client-card:hover .client-name {
    color: var(--accent);
  }

  /* ===== Footer link ===== */
  .venture-link {
    margin-top: auto;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .venture-link:hover {
    color: var(--accent-hover);
  }

  /* ===== Responsive ===== */
  @media (max-width: 820px) {
    .ventures-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 420px) {
    .venture-card {
      padding: 1.5rem;
    }

    .client-grid {
      gap: 0.6rem;
    }
  }
</style>
