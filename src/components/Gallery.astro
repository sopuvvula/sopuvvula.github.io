---
const photos = [
  { file: 'image1.jpg', caption: 'With my mom, dad, and sister at the temple' },
  { file: 'image2.jpg', caption: 'Brunch date with Amina!' },
  { file: 'image3.jpg', caption: "Dressed up with Amina at my friend Will's wedding" },
  { file: 'image4.jpg', caption: "Dinner with Amina for her 24th birthday" },
  { file: 'image5.jpg', caption: "With uncle & aunt at sister's wedding in India" },
  { file: 'image6.jpg', caption: 'At the Del Mar harbor with my friend Dorian' },
  { file: 'image7.jpg', caption: 'Boba tea with my good friends Snehesh, Thao Vy, and Pranim' },
  { file: 'image8.jpg', caption: 'Axe throwing with my childhood friends Ishaan, Kalp, and Rohan' },
  { file: 'image9.jpg', caption: 'Exploring downtown Chicago' },
  { file: 'image10.jpg', caption: 'Hiking with a view in San Diego' },
];
---

<section id="gallery" class="section" aria-label="Photo gallery">
  <span class="section-label">// gallery</span>
  <div class="container">
    <h2 class="section-title fade-in">Life Outside of Work</h2>
    <div class="gallery-grid fade-in">
      {photos.map((photo) => (
        <figure class="gallery-item">
          <img
            src={`/images/${photo.file}`}
            alt={photo.caption}
            loading="lazy"
            width="400"
            height="400"
          />
          <figcaption>{photo.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .gallery-item {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    background: var(--bg-card);
    border: 1px solid var(--border);
    backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .gallery-item:hover {
    border-color: var(--border-hover);
    box-shadow: 0 4px 30px var(--shadow);
    transform: scale(1.05);
  }

  .gallery-item img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  figcaption {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
