---
import { Image } from 'astro:assets';
import aboutImage from '../assets/images/image3.jpg';
---

<section id="about" class="section" aria-label="About me">
  <span class="section-label">// about</span>
  <div class="container">
    <h2 class="section-title fade-in">About Me</h2>
    <div class="about-content fade-in">
      <div class="about-text">
        <p>
          I'm a DevOps Engineer at Alarm.com, where I lead CI for the device
          engineering team and run GitHub Enterprise. I rebuilt our firmware
          build and source-control infrastructure into a fast, modern platform
          that handles 500+ builds a day for hundreds of engineers across the
          US, India, and Ukraine.
        </p>
        <p>
          Day to day that means Kubernetes infrastructure, CI/CD pipelines,
          build performance, and AI tooling. Recently I moved the team off
          Bamboo onto GitHub Actions and off Bitbucket onto GitHub, and I
          maintain a shared library of AI skills that engineers across teams
          build on.
        </p>
        <div class="about-details">
          <div class="detail">
            <span class="detail-label">Location</span>
            <span class="detail-value">San Diego, CA</span>
          </div>
          <div class="detail">
            <span class="detail-label">Education</span>
            <span class="detail-value">B.S. Computer Science, UMD</span>
          </div>
        </div>
      </div>
      <div class="about-photo">
        <Image
          src={aboutImage}
          alt="Dressed up with Amina at my friend Will's wedding"
          class="profile-img"
          width={720}
          height={880}
          quality={100}
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about-content {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-size: 1.05rem;
  }

  .about-details {
    display: flex;
    gap: 3rem;
    margin-top: 2rem;
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-label {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    font-weight: 500;
  }

  .detail-value {
    font-size: 1rem;
    color: var(--text);
    font-weight: 500;
  }

  .about-photo {
    flex-shrink: 0;
  }

  .profile-img {
    width: 360px;
    height: 440px;
    border-radius: 16px;
    object-fit: cover;
    object-position: top;
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .about-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-photo {
      order: -1;
    }

    .profile-img {
      width: 280px;
      height: 340px;
    }

    .about-details {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
