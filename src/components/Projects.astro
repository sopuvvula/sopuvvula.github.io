---
const projects = [
  {
    title: 'Firmware CI Platform Redesign',
    description:
      'Rebuilt Alarm.com\'s entire firmware CI infrastructure, replacing legacy shared builds with standardized, reproducible pipelines. Achieved 6× build time reduction and migrated to a 15-node bare-metal Kubernetes cluster.',
    tags: ['Kubernetes', 'Bamboo', 'Java Specs', 'LUN Storage'],
    github: '',
    live: '',
  },
  {
    title: 'RAG-Based Support Agent',
    description:
      'Built an internal AI-powered support agent using Python, FastAPI, and Azure OpenAI that integrates Confluence and Jira data. Currently piloting with 200+ engineers to reduce repetitive Tier-1 support inquiries.',
    tags: ['Python', 'FastAPI', 'Azure OpenAI', 'RAG'],
    github: '',
    live: '',
  },
  {
    title: 'CI Telemetry & Observability',
    description:
      'Designed automated telemetry pipelines powering Grafana and PowerBI dashboards across 500 daily builds. Surfaces failure rates, queue times, build trends, and workload distribution for engineering leadership.',
    tags: ['Grafana', 'PowerBI', 'Python', 'Data Pipelines'],
    github: '',
    live: '',
  },
  {
    title: 'AWS Automation Workflows',
    description:
      'Built AWS-based automation workflows for a federal agency using Lambda, DynamoDB, SES, and SNS to generate recurring analytics and system health reports.',
    tags: ['AWS Lambda', 'DynamoDB', 'SES', 'SNS'],
    github: '',
    live: '',
  },
  {
    title: 'Web-Based Drone Controller',
    description:
      'Created a globe-based drone controller interface using C, Node.js, and Cesium.js with real-time communication protocols. Included a collision avoidance system for autonomous flight.',
    tags: ['C', 'Node.js', 'Cesium.js', 'Embedded'],
    github: '',
    live: '',
  },
  {
    title: 'Linux Shell in C',
    description:
      'Built a Unix shell from scratch in C with support for boolean operations, pipes, and file redirection.',
    tags: ['C', 'Systems Programming', 'Unix'],
    github: '',
    live: '',
  },
  {
    title: 'Lexer, Parser & Interpreter',
    description:
      'Wrote a lexer, parser, and interpreter in OCaml for a custom programming language. One of my favorite school projects.',
    tags: ['OCaml', 'Compilers', 'Language Design'],
    github: '',
    live: '',
  },
];
---

<section id="projects" class="section" aria-label="Projects">
  <span class="section-label">// projects</span>
  <div class="container">
    <h2 class="section-title fade-in">Projects</h2>
    <div class="projects-grid fade-in">
      {projects.map((project) => (
        <article class="project-card">
          <div class="project-body">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-description">{project.description}</p>
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="project-links">
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" aria-label={`${project.title} source code`}>
                Code
              </a>
            )}
            {project.live && (
              <a href={project.live} target="_blank" rel="noopener noreferrer" aria-label={`${project.title} live demo`}>
                Live Demo
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '{ }';
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.7rem;
    color: var(--label-color);
  }

  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 4px 30px var(--shadow);
  }

  .project-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--heading);
    margin-bottom: 0.75rem;
  }

  .project-description {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--tag-text);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    border: 1px solid var(--tag-border);
  }

  .project-links {
    display: flex;
    gap: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    min-height: 1rem;
  }

  .project-links a {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .project-links a:hover {
    color: var(--accent-hover);
  }

  .project-links:empty {
    border-top: none;
    padding-top: 0;
    min-height: 0;
  }

  @media (max-width: 480px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
